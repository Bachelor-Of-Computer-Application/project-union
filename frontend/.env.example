# ─────────────────────────────────────────────────────────────────
# FoodExpress — Frontend environment variables
# Copy this file to .env and fill in your values.
# All variables must be prefixed with VITE_ to be exposed to the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# URL of the Django backend API (no trailing slash)
VITE_API_BASE=http://localhost:8000/api

# Root URL of the Django backend (used to construct media/image URLs)
VITE_MEDIA_BASE=http://localhost:8000
