# ─────────────────────────────────────────────────────────────────
# FoodExpress — Backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Generate a strong secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-me-before-deploying

# Set to False in production
DJANGO_DEBUG=True

# Space-separated list of allowed hosts, e.g. "yourdomain.com www.yourdomain.com"
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Comma-separated list of allowed CORS origins for the React frontend.
# Leave blank to allow all origins when DEBUG=True (dev only).
# Example for production: DJANGO_CORS_ORIGINS=https://foodexpress.example.com
DJANGO_CORS_ORIGINS=

# ─────────────────────────────────────────────────────────────────
# eSewa Payment Gateway (Sandbox/Test Environment)
# ─────────────────────────────────────────────────────────────────
# For testing, use these sandbox credentials:
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# Frontend callback URLs (adjust based on your frontend domain)
# After payment, user will be redirected to these URLs
ESEWA_SUCCESS_CALLBACK_URL=http://localhost:5173/orders/payment-success
ESEWA_FAILURE_CALLBACK_URL=http://localhost:5173/orders/payment-failure

# ─────────────────────────────────────────────────────────────────
# Email Configuration
# ─────────────────────────────────────────────────────────────────
# During development, leave EMAIL_BACKEND as the console backend to
# print emails to the terminal instead of sending them.
#
# To send real emails with Gmail:
#   1. Enable 2-Step Verification on your Google account
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Set EMAIL_HOST_USER to your Gmail address
#   4. Set EMAIL_HOST_PASSWORD to the 16-character App Password
#   5. Change EMAIL_BACKEND to smtp
#
# Console backend (dev) — prints emails to the Django terminal:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP backend (production) — actually sends emails:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=QuickServer1 <your@gmail.com>
