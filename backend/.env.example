# ─────────────────────────────────────────────────────────────────
# FoodExpress — Backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Generate a strong secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-me-before-deploying

# Set to False in production
DJANGO_DEBUG=True

# Space-separated list of allowed hosts, e.g. "yourdomain.com www.yourdomain.com"
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Comma-separated list of allowed CORS origins for the React frontend.
# Leave blank to allow all origins when DEBUG=True (dev only).
# Example for production: DJANGO_CORS_ORIGINS=https://foodexpress.example.com
DJANGO_CORS_ORIGINS=

# ─────────────────────────────────────────────────────────────────
# eSewa Payment Gateway (Sandbox/Test Environment)
# ─────────────────────────────────────────────────────────────────
# For testing, use these sandbox credentials:
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# Frontend callback URLs (adjust based on your frontend domain)
# After payment, user will be redirected to these URLs
ESEWA_SUCCESS_CALLBACK_URL=http://localhost:5173/orders/payment-success
ESEWA_FAILURE_CALLBACK_URL=http://localhost:5173/orders/payment-failure
